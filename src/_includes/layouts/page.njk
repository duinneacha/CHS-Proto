---
layout: layouts/base.njk
---
<article class="page">
  {% if page.url == "/membership/current-membership/" %}
  <aside class="membership-banner">
    <h2>Join or renew your membership</h2>
    <p>Membership supports lectures, research, and the care of our local history. The more members we have, the stronger the society.</p>
    <form class="paypal-form paypal-form-banner" action="https://www.paypal.com/cgi-bin/webscr" method="post" target="_blank" rel="noopener noreferrer">
      <input type="hidden" name="cmd" value="_s-xclick">
      <input type="hidden" name="hosted_button_id" value="LCZ8X5MTUY8JE">
      <input type="image" src="{{ '/assets/Styles/Images/SubscribeButton.png' | url }}" border="0" name="submit" alt="Renew membership with PayPal">
    </form>
    <p class="membership-banner-note">Or email <a href="mailto:{{ site.email }}">{{ site.email }}</a> / use the contact form.</p>
  </aside>
  {% endif %}
  <div class="page-body prose">
    {{ content | safe }}
  </div>
</article>
