<a class="skip-link" href="#main">Skip to content</a>
<header class="site-header">
  <div class="header-bar">
    <a class="brand" href="{{ '/' | url }}">
      <img class="brand-mark" src="{{ '/assets/Styles/Images/CDHSLogo.png' | url }}" width="200" height="146" alt="">
      <span class="brand-text">
        <span class="brand-name">{{ site.name }}</span>
      </span>
    </a>

    <div class="header-actions">
      <a class="btn btn-membership" href="{{ '/membership/current-membership/' | url }}">Join or Renew Membership</a>
    </div>

    <div class="header-mobile-tools">
      <a class="btn btn-membership btn-membership-mobile" href="{{ '/membership/current-membership/' | url }}">Join</a>
      <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="site-nav" data-nav-toggle>
        <span class="nav-toggle-bars" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="nav-toggle-label" data-nav-toggle-label>Menu</span>
      </button>
    </div>
  </div>

  <nav id="site-nav" class="site-nav" aria-label="Primary" data-site-nav>
    <div class="nav-mobile-panel">
      <a class="btn btn-membership btn-membership-nav" href="{{ '/membership/current-membership/' | url }}">Join or Renew Membership</a>
    </div>
    <ul class="nav-list">
      {% for item in navigation %}
      <li class="nav-item{% if item.children %} has-children{% endif %}">
        {% if item.children %}
        <button type="button" class="nav-parent" data-nav-parent aria-expanded="false">
          <span>{{ item.label }}</span>
          <span class="nav-chevron" aria-hidden="true"></span>
        </button>
        <ul class="nav-sub">
          {% for child in item.children %}
          <li>
            {% if child.external %}
            <a href="{{ child.url }}" target="_blank" rel="noopener noreferrer">{{ child.label }}</a>
            {% else %}
            <a href="{{ child.url | url }}"{% if page.url | navActive(child.url) %} aria-current="page"{% endif %}>{{ child.label }}</a>
            {% endif %}
          </li>
          {% endfor %}
        </ul>
        {% else %}
        <a href="{{ item.url | url }}">{{ item.label }}</a>
        {% endif %}
      </li>
      {% endfor %}
      <li class="nav-item nav-map">
        <a class="nav-map-link" href="{{ '/map/' | url }}">Map</a>
      </li>
    </ul>
  </nav>
</header>
